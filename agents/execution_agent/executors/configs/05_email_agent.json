{
  "agent_name": "email_agent",
  "agent_version": "v1",
  "department": "cross-dept",
  "risk_tier": "medium",
  "approval": "single_confirm_if_low_confidence",
  "confidence_threshold": 0.85,
  "steps": [
    {
      "name": "summarise_attachments",
      "type": "processor",
      "class": "LLMGenerator",
      "config": {
        "prompt_template": "summarise_attachment",
        "run_if": "task.has_attachments == true"
      }
    },
    {
      "name": "draft_reply",
      "type": "processor",
      "class": "LLMGenerator",
      "config": {
        "prompt_template": "draft_email_reply",
        "temperature": 0.3,
        "tone_rules": {
          "IT": "direct",
          "HR": "empathetic",
          "Finance": "formal"
        }
      }
    },
    {
      "name": "score_confidence",
      "type": "processor",
      "class": "LLMGenerator",
      "config": {
        "prompt_template": "self_rate_confidence",
        "output_field": "confidence_score"
      }
    },
    {
      "name": "compliance_check",
      "type": "extractor",
      "class": "DBExtractor",
      "config": {
        "service": "compliance_checker",
        "action_type": "send_email"
      }
    },
    {
      "name": "send_email",
      "type": "dispatcher",
      "class": "EmailDispatcher",
      "config": {
        "recipient_field": "task.requester_name",
        "log_audit": true
      }
    }
  ],
  "on_failure": "escalate",
  "outcome_signal": true
}